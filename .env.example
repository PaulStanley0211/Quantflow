# QuantFlow — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────


# ── Anthropic API ─────────────────────────────────────────────
# Required by: Morning Briefing, Technical Setup Scanner,
#              Trade Journal, Trade Executor
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...


# ── Gmail SMTP / IMAP ─────────────────────────────────────────
# Required by: Morning Briefing, Trade Journal (--email flag),
#              Trade Executor, Risk Monitor
#
# EMAIL_SENDER    — the Gmail address that sends/receives emails
# EMAIL_PASSWORD  — 16-character App Password (NOT your account password)
#                   Generate at: https://myaccount.google.com/apppasswords
#                   (Google account must have 2-Step Verification enabled)
# EMAIL_RECEIVER  — the address where reports and alerts are delivered
EMAIL_SENDER=your_gmail@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_RECEIVER=recipient@gmail.com
